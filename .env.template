# ============================================================
#         StudyBuddyV3BOT — Environment Configuration
#         Copy this file to .env and fill in your values
# ============================================================

# ------------------------------------------------------------
# 🤖 TELEGRAM BOT
# ------------------------------------------------------------
# Get from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# ------------------------------------------------------------
# 🗄️ MONGODB DATABASE
# ------------------------------------------------------------
# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# Database name (you can keep default)
DB_NAME=studybuddy_db

# ------------------------------------------------------------
# 🧠 OPENAI API
# ------------------------------------------------------------
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here

# OpenAI model to use (recommended: gpt-4o-mini for cost efficiency)
OPENAI_MODEL=gpt-4o-mini

# Max tokens per AI response
OPENAI_MAX_TOKENS=1000

# AI temperature (0.0 = focused, 1.0 = creative)
OPENAI_TEMPERATURE=0.7

# ------------------------------------------------------------
# 👑 ADMIN CONFIGURATION
# ------------------------------------------------------------
# Your Telegram numeric user ID (get from @userinfobot)
ADMIN_IDS=123456789,987654321

# Admin panel secret passphrase (extra security layer)
ADMIN_SECRET=your_admin_secret_passphrase_here

# ------------------------------------------------------------
# 🚦 RATE LIMITING
# ------------------------------------------------------------
# Max messages per user per minute
RATE_LIMIT_MESSAGES=10

# Max AI requests per user per hour
AI_RATE_LIMIT_PER_HOUR=20

# Cooldown seconds after rate limit hit
RATE_LIMIT_COOLDOWN=60

# ------------------------------------------------------------
# 🌍 LANGUAGE & LOCALIZATION
# ------------------------------------------------------------
# Default bot language (en, hi, bn, ar)
DEFAULT_LANGUAGE=en

# ------------------------------------------------------------
# ⚙️ BOT SETTINGS
# ------------------------------------------------------------
# Bot environment: development | production
ENVIRONMENT=production

# Enable maintenance mode: true | false
MAINTENANCE_MODE=false

# Maintenance message shown to users
MAINTENANCE_MESSAGE=Bot is under maintenance. Please try again later.

# Max notes per user
MAX_NOTES_PER_USER=50

# Max note length (characters)
MAX_NOTE_LENGTH=2000

# ------------------------------------------------------------
# 📝 LOGGING
# ------------------------------------------------------------
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs/studybuddy.log

# Max log file size in MB before rotation
LOG_MAX_SIZE_MB=10

# Number of backup log files to keep
LOG_BACKUP_COUNT=5

# ------------------------------------------------------------
# 🔄 CONTEXT MEMORY (AI Chat History)
# ------------------------------------------------------------
# Max messages to keep in AI context per user
AI_CONTEXT_MAX_MESSAGES=20

# Context expiry in seconds (1 hour = 3600)
AI_CONTEXT_EXPIRY=3600

# ------------------------------------------------------------
# 📡 POLLING SETTINGS
# ------------------------------------------------------------
# Polling interval in seconds
POLL_INTERVAL=1.0

# Polling timeout in seconds
POLL_TIMEOUT=30

# Drop pending updates on startup: true | false
DROP_PENDING_UPDATES=true
